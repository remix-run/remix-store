  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "overrides": {
      "undici": "7.24.0",
      "qs": "6.15.2",
      "ws": "8.20.1",
      "liquidjs": "10.27.0",
      "lodash": "4.18.1",
      "cookie": "1.0.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react-router": "7.15.1",
        "@react-router/dev": "7.15.1",
        "@shopify/mini-oxygen": "4.1.0"
      }
    }
  }
